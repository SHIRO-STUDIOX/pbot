# Telegram Bot Token from @BotFather (Required)
BOT_TOKEN=your_bot_token_here

# Simulation Delay in seconds (default: 2.0)
SIMULATION_DELAY=2.0

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Proxy Relay Configurations (for censored/restricted servers in Iran)
USE_PROXY_RELAY=false
GAS_URL=https://script.google.com/macros/s/XXXXXX/exec
RELAY_TOKEN=MySecretToken9876!
LOCAL_PROXY_URL=http://telegram-proxy:8080

# Docker Compose Profiles (Determines if the proxy container runs)
# - Set to "proxy" to run the local proxy container alongside the bot (Iran server)
# - Leave blank/commented out to NOT run the proxy container (Foreign server)
# COMPOSE_PROFILES=proxy
